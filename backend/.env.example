# ===== アプリ設定 =====
NODE_ENV=production
PORT=3000

# CORS許可オリジン（カンマ区切りで複数指定可）
ALLOWED_ORIGINS=https://jin-omamori-app-a9j9.vercel.app

# ===== データベース設定 =====
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=jin_user
DB_PASSWORD=jin_password
DB_DATABASE=jin_omamori

# ===== Railway PostgreSQL設定（本番環境）=====
# RailwayがDATABASE_URLを自動注入します。設定すると個別のDB_*変数より優先されます。
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# ===== JWT設定 =====
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# ===== Apple Sign In設定 =====
APPLE_CLIENT_ID=com.yourcompany.jin-omamori
APPLE_TEAM_ID=YOUR_TEAM_ID
APPLE_KEY_ID=YOUR_KEY_ID
# Apple認証キー（PEM形式）— 改行は\nに変換
APPLE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nYOUR_APPLE_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----

# ===== Firebase設定（プッシュ通知用） =====
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY=your-firebase-private-key
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com

# ===== Stripe設定 =====
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
